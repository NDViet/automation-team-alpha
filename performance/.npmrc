# @ndviet packages are published to GitHub Packages.
# Set NODE_AUTH_TOKEN to a PAT with read:packages scope before running npm install.
#
#   export NODE_AUTH_TOKEN=<your-github-pat>
#   npm install
#   npm run build
#
# In CI, NODE_AUTH_TOKEN is automatically provided by GITHUB_TOKEN.
@ndviet:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
