<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Grid-optimised cross-browser suite.
  All 15 test blocks run simultaneously — the Selenium Grid distributes
  each RemoteWebDriver session to the matching browser node.

  thread-count="15" → one thread per <test> block (5 blocks × 3 browsers).
  Each node is configured with SE_NODE_MAX_SESSIONS=5 in docker-compose.yml
  to satisfy up to 5 concurrent sessions of the same browser type.

  Usage (local JVM → grid):
    ./gradlew test \
      -Dwebdriver.target=REMOTE \
      -Dselenium.hub.url=http://localhost:4444/wd/hub \
      -Dsuite=testng-grid.xml
-->
<suite name="The Internet – Grid Cross-Browser Suite" verbose="1" parallel="tests" thread-count="15">

    <!-- ═══════════════════════════ CHROME ═══════════════════════════ -->
    <test name="Chrome – Authentication Tests">
        <parameter name="browser" value="chrome"/>
        <classes><class name="org.ndviet.tests.authentication.AuthenticationTest"/></classes>
    </test>

    <test name="Chrome – Form Interaction Tests">
        <parameter name="browser" value="chrome"/>
        <classes><class name="org.ndviet.tests.form.FormInteractionTest"/></classes>
    </test>

    <test name="Chrome – Alerts and Popups Tests">
        <parameter name="browser" value="chrome"/>
        <classes><class name="org.ndviet.tests.alerts.AlertsAndPopupsTest"/></classes>
    </test>

    <test name="Chrome – Dynamic Content Tests">
        <parameter name="browser" value="chrome"/>
        <classes><class name="org.ndviet.tests.dynamic.DynamicContentTest"/></classes>
    </test>

    <test name="Chrome – Navigation and Windows Tests">
        <parameter name="browser" value="chrome"/>
        <classes><class name="org.ndviet.tests.navigation.NavigationAndWindowsTest"/></classes>
    </test>

    <!-- ════════════════════════════ EDGE ════════════════════════════ -->
    <test name="Edge – Authentication Tests">
        <parameter name="browser" value="edge"/>
        <classes><class name="org.ndviet.tests.authentication.AuthenticationTest"/></classes>
    </test>

    <test name="Edge – Form Interaction Tests">
        <parameter name="browser" value="edge"/>
        <classes><class name="org.ndviet.tests.form.FormInteractionTest"/></classes>
    </test>

    <test name="Edge – Alerts and Popups Tests">
        <parameter name="browser" value="edge"/>
        <classes><class name="org.ndviet.tests.alerts.AlertsAndPopupsTest"/></classes>
    </test>

    <test name="Edge – Dynamic Content Tests">
        <parameter name="browser" value="edge"/>
        <classes><class name="org.ndviet.tests.dynamic.DynamicContentTest"/></classes>
    </test>

    <test name="Edge – Navigation and Windows Tests">
        <parameter name="browser" value="edge"/>
        <classes><class name="org.ndviet.tests.navigation.NavigationAndWindowsTest"/></classes>
    </test>

    <!-- ══════════════════════════ FIREFOX ═══════════════════════════ -->
    <test name="Firefox – Authentication Tests">
        <parameter name="browser" value="firefox"/>
        <classes><class name="org.ndviet.tests.authentication.AuthenticationTest"/></classes>
    </test>

    <test name="Firefox – Form Interaction Tests">
        <parameter name="browser" value="firefox"/>
        <classes><class name="org.ndviet.tests.form.FormInteractionTest"/></classes>
    </test>

    <test name="Firefox – Alerts and Popups Tests">
        <parameter name="browser" value="firefox"/>
        <classes><class name="org.ndviet.tests.alerts.AlertsAndPopupsTest"/></classes>
    </test>

    <test name="Firefox – Dynamic Content Tests">
        <parameter name="browser" value="firefox"/>
        <classes><class name="org.ndviet.tests.dynamic.DynamicContentTest"/></classes>
    </test>

    <test name="Firefox – Navigation and Windows Tests">
        <parameter name="browser" value="firefox"/>
        <classes><class name="org.ndviet.tests.navigation.NavigationAndWindowsTest"/></classes>
    </test>

</suite>
